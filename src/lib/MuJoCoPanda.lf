target C

import MuJoCoAuto from "MuJoCoAuto.lf"

/**
 * Franka Emika Panda robot.
 *
 * @author Edward A. Lee
 */
reactor MuJoCoPanda(
    model_file: string = {= LF_SOURCE_DIRECTORY "/models/mujoco_menagerie/franka_emika_panda/scene.xml" =})
    extends MuJoCoAuto {
  input[8] motor: double
  output[8] encoder: double
  reaction(motor) {=
    advance_simulator();
    for (int i = 0; i < 8; i++) {
      self->context.d->ctrl[i] = motor[i]->value;
    }
  =}
}
