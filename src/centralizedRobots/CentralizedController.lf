/*
* Top-level reactor that composes the full robot control system.
* Containing a path planning unit, a RobotStateReceiver (reading sensor values from the robot) and a motor control unit. 
*
* See [README.md](../README.md) for prerequisites and installation instructions.
* 
* Date:
*   2026-03-30
*
* @author Friederike Bruns
*/

target C {
  // On MacOS, GLFW can only be accessed from the main thread.
  // The MuJoCoPanda reactor needs to be on this thread.
  // Currently, the only way to ensure this is to set the workers to 1.
  workers: 1,
  // Because of physical action for the keypresses.
  keepalive: true,
  // To use the lf_initialize_double function, we need to include the following:
  cmake-include: ["/lib/c/reactor-c/util/initialize_from_file.cmake"],
  files: [
      "/lib/c/reactor-c/util/initialize_from_file.c",
      "/lib/c/reactor-c/util/initialize_from_file.h"]
}

import RealRobots from "RealRobots.lf"
//import TwoRobots from "../lib/TwoRobots.lf"
//import MuJoCoWidowX from "../lib/MuJoCoWidowX.lf"
//import MuJoCoVX300S from "../lib/MuJoCoVX300S.lf"
import Pathplanner from "Pathplanner.lf"
import ReadSensorDataUnit from "ReadSensorDataUnit.lf"
import SetMotor from "SetMotor.lf"

preamble {=
  #include "initialize_from_file.h"
  // If built without GLFW (e.g., using RealRobots instead of TwoRobots),
  // these constants are missing. Values must match those in poll_keyboard_thread
  // in RealRobots.lf (see there). TODO: Generalized way to poll keyboard input in C reactors.
  #ifndef GLFW_PRESS
  #define GLFW_PRESS 1
  #define GLFW_KEY_BACKSPACE 259
  #define GLFW_KEY_Q 81
  #endif
=}

reactor RobotControl(
    period: time = 100 ms,
    dataset: int = 0,
    step: double = 0.05,
    high_limit: double = 1.0,
    low_limit: double = -1.0,
    bank_index: int = 0,
    parameter_file: string = "") {
  input restart: bool
  input qpos: double
  input qvel: double
  output command: double
  timer t(0, period)
  state motor: double = 0.0


  reaction(startup) {=
    if (self->parameter_file != NULL && self->parameter_file[0] != '\0') {
      int n = lf_initialize_double(
          self->parameter_file,
          ',',
          (size_t)((9 * self->dataset) + self->bank_index + 1), // +1 skips the header row
          &self->step,
          &self->high_limit,
          &self->low_limit,
          NULL);
    }
  =}

  reaction(restart) {=
    self->motor = 0.0;
  =}

  planner = new Pathplanner(
  period = period,
  step = step, 
  high_limit = 1.0,
  low_limit = -1.0);
  motor_ctrl = new SetMotor(period = period);
  ReadData = new ReadSensorDataUnit(period = period);

  // State feedback  → control
  qpos -> ReadData.qpos;
  qvel -> ReadData.qvel;
  // Path planner → control
  planner.desired -> motor_ctrl.motor;
 // planner.feedforward -> set_motor.ff;
  motor_ctrl.command -> command;

}

main reactor CentralizedController(dataset: int = 0){
  timer read_state_timer(0, 500 ms)
  m = new RealRobots(left_port = "/dev/ttyUSB0", right_port = "/dev/ttyUSB1")
  //m = new TwoRobots(frame_period = 33 ms)
  cL = new[8] RobotControl(
      dataset=dataset,
      period = 100 ms,
      parameter_file = {= LF_SOURCE_DIRECTORY "/RobotControlParametersvx300s.csv" =})
  cR = new[8] RobotControl(
      dataset=dataset,
      period = 100 ms,
      parameter_file = {= LF_SOURCE_DIRECTORY "/RobotControlParametersWidowX.csv" =})

  cL.command -> m.Lmotor;
  cR.command -> m.Rmotor;
  m.Ljoint_pos -> cL.qpos;
  m.Ljoint_vel -> cL.qvel;
  m.Rjoint_pos -> cR.qpos;
  m.Rjoint_vel -> cR.qvel;

  reaction(startup) {=
    lf_print("*** Backspace to reset.");
    lf_print("*** Type q to quit.\n");
  =}

  reaction(m.key) -> m.restart, cL.restart, cR.restart {=
    // If backspace: reset simulation
    // If q or Q: quit
    if (m.key->value.act==GLFW_PRESS) {
      if (m.key->value.key==GLFW_KEY_BACKSPACE) {
        lf_set(m.restart, true);
        for (int i = 0; i < 8; i++) {
          lf_set(cL[i].restart, true);
          lf_set(cR[i].restart, true);
        }
      } else if (m.key->value.key==GLFW_KEY_Q) {
        lf_request_stop();
      }
    }
  =}

  reaction(read_state_timer) -> m.read_state {=
    lf_set(m.read_state, true);
  =}

  reaction(m.Ljoint_pos, m.Ljoint_vel, m.Rjoint_pos, m.Rjoint_vel) {=
    lf_print(
        "L qpos=%.4f %.4f %.4f %.4f %.4f %.4f %.4f %.4f | R qpos=%.4f %.4f %.4f %.4f %.4f %.4f %.4f %.4f | L qvel=%.4f %.4f %.4f %.4f %.4f %.4f %.4f %.4f | R qvel=%.4f %.4f %.4f %.4f %.4f %.4f %.4f %.4f",
        m.Ljoint_pos[0]->value,
        m.Ljoint_pos[1]->value,
        m.Ljoint_pos[2]->value,
        m.Ljoint_pos[3]->value,
        m.Ljoint_pos[4]->value,
        m.Ljoint_pos[5]->value,
        m.Ljoint_pos[6]->value,
        m.Ljoint_pos[7]->value,
        m.Rjoint_pos[0]->value,
        m.Rjoint_pos[1]->value,
        m.Rjoint_pos[2]->value,
        m.Rjoint_pos[3]->value,
        m.Rjoint_pos[4]->value,
        m.Rjoint_pos[5]->value,
        m.Rjoint_pos[6]->value,
        m.Rjoint_pos[7]->value,
        m.Ljoint_vel[0]->value,
        m.Ljoint_vel[1]->value,
        m.Ljoint_vel[2]->value,
        m.Ljoint_vel[3]->value,
        m.Ljoint_vel[4]->value,
        m.Ljoint_vel[5]->value,
        m.Ljoint_vel[6]->value,
        m.Ljoint_vel[7]->value,
        m.Rjoint_vel[0]->value,
        m.Rjoint_vel[1]->value,
        m.Rjoint_vel[2]->value,
        m.Rjoint_vel[3]->value,
        m.Rjoint_vel[4]->value,
        m.Rjoint_vel[5]->value,
        m.Rjoint_vel[6]->value,
        m.Rjoint_vel[7]->value);
  =}
}

